# Copy this file to `.env` and you're done:
#   cp .env.example .env

# Where to forward /api/* requests. Local backend by default.
# Point at staging if you don't want to run the backend:
#   API_URL=https://bloom.comhairle.scot
#   API_PREFIX=/api
API_URL=http://localhost:3000

# --- Local dev region (optional) ---
# Run `./scripts/seed-dev.sh` to mint these IDs against your local backend.
# When all four are set, a 'dev' region appears at http://dev.localhost:5173.
# Leave them unset (or remove) for any non-local environment.
# PUBLIC_DEV_CONVERSATION_ID=
# PUBLIC_DEV_INVITE_ID=
# PUBLIC_DEV_POLIS_ID=
# PUBLIC_DEV_POLIS_WORKFLOW_STEP_ID=
